{
  "version": 3,
  "outputDirectory": "public",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[[...all]].ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
