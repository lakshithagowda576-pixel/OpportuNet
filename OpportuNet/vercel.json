{
  "version": 3,
  "builds": [
    {
      "src": "artifacts/job-portal/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "artifacts/job-portal/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[[...all]].ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
