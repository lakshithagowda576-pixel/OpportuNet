{
  "version": 2,
  "installCommand": "npm i -g pnpm@latest && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": ".",
  "framework": null,
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.mjs"
    }
  ]
}