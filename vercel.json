{
  "version": 3,
  "outputDirectory": "OpportuNet/artifacts/job-portal/dist/public",
  "builds": [
    {
      "src": "OpportuNet/artifacts/job-portal/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/OpportuNet/api/[[...all]].ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
