{
  "version": 2,
  "installCommand": "npm i -g pnpm@latest && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm -C artifacts/job-portal run build && pnpm -C artifacts/api-server run build",
  "outputDirectory": ".",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}