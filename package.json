{
  "name": "opportu-net-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --filter \"@workspace/api-server\" --filter \"@workspace/job-portal\" --parallel dev",
    "dev:all": "pnpm -r --parallel dev",
    "install:all": "pnpm install",
    "build": "pnpm -C artifacts/job-portal run build && pnpm -C artifacts/api-server run build",
    "build:vercel": "pnpm -C artifacts/job-portal run build",
    "typecheck": "tsc --build && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "start:api": "pnpm -C artifacts/api-server run start",
    "seed": "pnpm -C scripts run seed --env-file=.env",
    "seed_pre_register_jobs": "pnpm -C scripts run seed_pre_register_jobs --env-file=.env",
    "seed_active_apps": "pnpm -C scripts run seed_active_apps",
    "seed_branding_links": "pnpm -C scripts run seed_branding_links --env-file=.env"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  }
}
